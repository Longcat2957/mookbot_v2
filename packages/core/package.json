{
	"name": "@mookbot/core",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./db": "./dist/db/index.js",
		"./screening": "./dist/screening/index.js",
		"./riot": "./dist/riot/index.js",
		"./mmr": "./dist/mmr/index.js",
		"./datadragon": "./dist/datadragon/index.js",
		"./test-utils/db-harness": "./dist/test-utils/db-harness.js"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"db:migrate": "tsx src/db/migrate.ts",
		"db:migrate:drop": "tsx src/db/migrate.ts --drop",
		"backfill:profile-icons": "tsx src/db/backfill-profile-icons.ts"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"ioredis": "^5.10.1",
		"pino": "^10.3.1",
		"pino-abstract-transport": "^3.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/ioredis-mock": "^8.2.7",
		"@types/node": "^25.6.0",
		"better-sqlite3": "^12.9.0",
		"ioredis-mock": "^8.13.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
