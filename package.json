{
	"name": "mookbot-v2",
	"private": true,
	"version": "0.2.8",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"typecheck": "pnpm -r typecheck",
		"build": "pnpm -r --workspace-concurrency=1 build",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"dev": "pnpm --filter \"./apps/*\" --parallel run dev",
		"dev:web": "pnpm --filter @mookbot/activity dev",
		"dev:api": "pnpm --filter @mookbot/api dev",
		"dev:bot": "pnpm --filter @mookbot/bot dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"version:patch": "pnpm version patch --no-git-tag-version",
		"version:minor": "pnpm version minor --no-git-tag-version",
		"version:major": "pnpm version major --no-git-tag-version",
		"docker:build": "scripts/docker-build.sh",
		"docker:push": "scripts/docker-push.sh",
		"docker:release": "scripts/docker-build.sh && scripts/docker-push.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	}
}
