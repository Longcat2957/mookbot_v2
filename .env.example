# =====================================================================
# Discord Bot / OAuth2 / Activity
# =====================================================================
# 봇 토큰 (Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=

# Application ID (Developer Portal → General Information → Application ID)
CLIENT_ID=

# 단일 길드 운영 시 — 슬래시 명령을 이 길드에만 등록 (즉시 반영). 비우면 글로벌 (반영 1시간).
GUILD_ID=

# OAuth2 Client Secret (Developer Portal → OAuth2 → Reset Secret) — Activity SDK token exchange 용
DISCORD_CLIENT_SECRET=

# Activity SDK 가 사용하는 client id — 일반적으로 CLIENT_ID 와 동일
VITE_DISCORD_CLIENT_ID=

# OAuth2 token exchange 시 redirect_uri — Developer Portal OAuth2 Redirects 에 등록된 값과 동일해야 함
# OAUTH_REDIRECT_URI=https://bot.mooklol.com

# 운영자 역할 이름 — 이 이름의 길드 role 보유자만 운영자 (다른 역할 동시 보유 무관).
# 미설정 시 기본 "BalanceTeam". 다른 이름을 쓰는 길드만 override.
# OPERATOR_ROLE_NAME=BalanceTeam

# =====================================================================
# Riot Games API
# =====================================================================
# https://developer.riotgames.com/ — 개발 키는 24시간마다 갱신 필요
RIOT_API_KEY=

# =====================================================================
# Cloudflare D1
# =====================================================================
# 계정 ID (대시보드 우측 사이드바)
CF_ACCOUNT_ID=

# D1 데이터베이스 UUID (Cloudflare 대시보드 → D1 → 데이터베이스 선택)
CLOUDFLARE_D1_DATABASE_ID=

# API 토큰 (D1:Edit 권한)
CLOUDFLARE_API_TOKEN=

# =====================================================================
# API 서버 / 세션
# =====================================================================
# 세션 쿠키 서명용 — `openssl rand -hex 32` 로 생성
SESSION_SECRET=

# Activity 백엔드 listen 주소 (Docker 내부에서 다른 컨테이너가 접근하려면 0.0.0.0)
API_PORT=3000
API_HOST=0.0.0.0

# =====================================================================
# Internal RPC (bot ↔ api)
# =====================================================================
# 봇이 api 의 /internal/notify 호출 시 사용 — `openssl rand -hex 32`
# 미설정 시 봇은 broadcast 안 함 (silent skip)
INTERNAL_API_KEY=

# 봇 → api 내부 호스트 (docker network 내). 기본: http://api:3000
# INTERNAL_API_BASE=http://api:3000

# api → bot 내부 호스트 (docker network 내). 기본: http://bot:3001
# Activity 에서 시리즈 생성/revert 시 봇이 Discord 모집 메시지 다시 그리도록 트리거.
# BOT_INTERNAL_BASE=http://bot:3001

# /로그 슬래시 → /logs 웹뷰 JWT 서명. `openssl rand -hex 32` 로 생성.
# 봇/api 공유 (반드시 동일 값). 미설정 시 /로그 명령어 비활성.
LOGS_JWT_SECRET=

# /로그 응답에 표시되는 base URL. 기본 https://bot.mooklol.com.
# LOGS_BASE_URL=https://bot.mooklol.com

# =====================================================================
# KV backend (Valkey/Redis)
# =====================================================================
# entry/pickban 드래프트 + read-through 캐시용. 미설정 시 D1 단일 backend 폴백.
# prod: docker compose 의 valkey 서비스 사용.
REDIS_URL=redis://valkey:6379

# =====================================================================
# 로깅 (선택)
# =====================================================================
# LOG_LEVEL=info
